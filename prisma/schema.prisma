generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id               Int                    @id @default(autoincrement())
  maxUserId        String                 @unique @map("max_user_id") @db.VarChar(100)
  displayName      String?                @map("display_name") @db.VarChar(255)
  phone            String?                @db.VarChar(30)
  createdAt        DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?              @default(now()) @map("updated_at") @db.Timestamp(6)
  appointments     AppointmentRequest[]
  completedVisits  CompletedVisit[]
  conversations    Conversation[]
  handoffs         Handoff[]
  messages         Message[]
  reminders        AppointmentReminder[]
  outboundMessages OutboundMessageQueue[]

  @@map("contacts")
}

model Conversation {
  id            Int                  @id @default(autoincrement())
  contactId     Int                  @map("contact_id")
  channel       String?              @default("MAX") @db.VarChar(50)
  status        String?              @default("active") @db.VarChar(50)
  lastMessageAt DateTime?            @map("last_message_at") @db.Timestamp(6)
  createdAt     DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?            @default(now()) @map("updated_at") @db.Timestamp(6)
  actions       AgentAction[]
  appointments  AppointmentRequest[]
  memory        ConversationMemory?
  contact       Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  handoffs      Handoff[]
  messages      Message[]

  @@map("conversations")
}

model Message {
  id                Int          @id @default(autoincrement())
  conversationId    Int          @map("conversation_id")
  contactId         Int          @map("contact_id")
  direction         String       @db.VarChar(20)
  role              String       @db.VarChar(30)
  text              String
  externalMessageId String?      @unique @map("external_message_id") @db.VarChar(160)
  rawPayload        Json?        @map("raw_payload")
  createdAt         DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  contact           Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("messages")
}

model ConversationProcessingLock {
  id          Int      @id @default(autoincrement())
  lockKey     String   @unique @map("lock_key") @db.VarChar(180)
  lockToken   String   @map("lock_token") @db.VarChar(80)
  lockedUntil DateTime @map("locked_until") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([lockedUntil])
  @@map("conversation_processing_locks")
}

model ConversationMemory {
  id             Int          @id @default(autoincrement())
  conversationId Int          @unique @map("conversation_id")
  memory         Json
  updatedAt      DateTime?    @default(now()) @map("updated_at") @db.Timestamp(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("conversation_memory")
}

model AppointmentRequest {
  id               Int                   @id @default(autoincrement())
  conversationId   Int                   @map("conversation_id")
  contactId        Int                   @map("contact_id")
  patientName      String?               @map("patient_name") @db.VarChar(255)
  phone            String?               @db.VarChar(30)
  complaint        String?
  requestedService String?               @map("requested_service") @db.VarChar(255)
  preferredDate    DateTime?             @map("preferred_date") @db.Date
  preferredTime    String?               @map("preferred_time") @db.VarChar(50)
  preferredDoctor  String?               @map("preferred_doctor") @db.VarChar(255)
  urgency          String?               @default("normal") @db.VarChar(50)
  status           String?               @default("new") @db.VarChar(50)
  consentToBook    Boolean?              @default(false) @map("consent_to_book")
  createdAt        DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?             @default(now()) @map("updated_at") @db.Timestamp(6)
  reminders        AppointmentReminder[]
  slot             AppointmentSlot?
  completedVisit   CompletedVisit?
  contact          Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conversation     Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("appointment_requests")
}

model AppointmentSlot {
  id                   Int                @id @default(autoincrement())
  appointmentRequestId Int                @unique @map("appointment_request_id")
  slotDate             DateTime           @map("slot_date") @db.Date
  slotTime             String             @map("slot_time") @db.VarChar(50)
  status               String?            @default("booked") @db.VarChar(50)
  createdAt            DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime?          @default(now()) @map("updated_at") @db.Timestamp(6)
  appointmentRequest   AppointmentRequest @relation(fields: [appointmentRequestId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([slotDate, slotTime])
  @@map("appointment_slots")
}

model AppointmentReminder {
  id                   Int                @id @default(autoincrement())
  appointmentRequestId Int                @map("appointment_request_id")
  contactId            Int                @map("contact_id")
  remindAt             DateTime           @map("remind_at") @db.Timestamp(6)
  type                 String?            @default("before_visit") @db.VarChar(50)
  status               String?            @default("pending") @db.VarChar(50)
  sentAt               DateTime?          @map("sent_at") @db.Timestamp(6)
  error                String?
  createdAt            DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime?          @default(now()) @map("updated_at") @db.Timestamp(6)
  appointmentRequest   AppointmentRequest @relation(fields: [appointmentRequestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contact              Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, remindAt])
  @@map("appointment_reminders")
}

model AgentAction {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  actionType     String       @map("action_type") @db.VarChar(100)
  reason         String?
  payload        Json?
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("agent_actions")
}

model Handoff {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  contactId      Int          @map("contact_id")
  reason         String?
  status         String?      @default("open") @db.VarChar(50)
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  resolvedAt     DateTime?    @map("resolved_at") @db.Timestamp(6)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("handoffs")
}

model ClinicSetting {
  id          Int       @id @default(autoincrement())
  key         String    @unique @db.VarChar(100)
  value       String
  description String?
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("clinic_settings")
}

model Doctor {
  id              Int              @id @default(autoincrement())
  fullName        String           @unique @map("full_name") @db.VarChar(255)
  position        String?          @db.VarChar(255)
  specialization  String?          @db.VarChar(255)
  phone           String?          @db.VarChar(30)
  active          Boolean          @default(true)
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamp(6)
  schedules       DoctorSchedule[]
  completedVisits CompletedVisit[]

  @@map("doctors")
}

model DoctorSchedule {
  id        Int       @id @default(autoincrement())
  doctorId  Int       @map("doctor_id")
  weekday   Int
  startTime String    @map("start_time") @db.VarChar(5)
  endTime   String    @map("end_time") @db.VarChar(5)
  cabinet   String?   @db.VarChar(50)
  active    Boolean   @default(true)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([doctorId, weekday, startTime, endTime])
  @@map("doctor_schedules")
}

model ServiceCategory {
  id        Int             @id @default(autoincrement())
  name      String          @unique @db.VarChar(255)
  sortOrder Int             @default(0) @map("sort_order")
  active    Boolean         @default(true)
  services  ClinicService[]

  @@map("service_categories")
}

model ClinicService {
  id              Int              @id @default(autoincrement())
  categoryId      Int?             @map("category_id")
  name            String           @db.VarChar(255)
  slug            String           @unique @db.VarChar(120)
  description     String?
  priceFrom       Int?             @map("price_from")
  priceTo         Int?             @map("price_to")
  durationMinutes Int?             @map("duration_minutes")
  active          Boolean          @default(true)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamp(6)
  category        ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  followUpRules   FollowUpRule[]
  completedVisits CompletedVisit[]

  @@map("clinic_services")
}

model FollowUpRule {
  id              Int            @id @default(autoincrement())
  serviceId       Int?           @map("service_id")
  name            String         @unique @db.VarChar(255)
  triggerEvent    String         @default("completed_visit") @map("trigger_event") @db.VarChar(100)
  afterDays       Int            @map("after_days")
  messageTemplate String         @map("message_template")
  active          Boolean        @default(true)
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?      @default(now()) @map("updated_at") @db.Timestamp(6)
  service         ClinicService? @relation(fields: [serviceId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@map("follow_up_rules")
}

model CompletedVisit {
  id                   Int                 @id @default(autoincrement())
  contactId            Int?                @map("contact_id")
  appointmentRequestId Int?                @unique @map("appointment_request_id")
  doctorId             Int?                @map("doctor_id")
  serviceId            Int?                @map("service_id")
  patientName          String              @map("patient_name") @db.VarChar(255)
  phone                String?             @db.VarChar(30)
  serviceName          String?             @map("service_name") @db.VarChar(255)
  visitDate            DateTime            @map("visit_date") @db.Date
  notes                String?
  createdAt            DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  contact              Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  appointmentRequest   AppointmentRequest? @relation(fields: [appointmentRequestId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  doctor               Doctor?             @relation(fields: [doctorId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  service              ClinicService?      @relation(fields: [serviceId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([visitDate])
  @@map("completed_visits")
}

model MaxMessageQueue {
  id                Int       @id @default(autoincrement())
  messageKey        String    @unique @map("message_key") @db.VarChar(80)
  chatId            String    @map("chat_id") @db.VarChar(120)
  chatName          String?   @map("chat_name") @db.VarChar(255)
  messageText       String    @map("message_text")
  externalMessageId String?   @map("external_message_id") @db.VarChar(120)
  source            String?   @db.VarChar(100)
  status            String    @default("queued") @db.VarChar(30)
  attempts          Int       @default(0)
  lockedUntil       DateTime? @map("locked_until") @db.Timestamp(6)
  lastError         String?   @map("last_error")
  n8nResponse       Json?     @map("n8n_response")
  rawPayload        Json?     @map("raw_payload")
  queuedAt          DateTime  @default(now()) @map("queued_at") @db.Timestamp(6)
  processedAt       DateTime? @map("processed_at") @db.Timestamp(6)
  sentAt            DateTime? @map("sent_at") @db.Timestamp(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([status, queuedAt])
  @@index([chatId, queuedAt])
  @@map("max_message_queue")
}

model BroadcastCampaign {
  id              Int                    @id @default(autoincrement())
  name            String?                @db.VarChar(255)
  prompt          String
  filters         Json?
  type            String                 @default("broadcast") @db.VarChar(50)
  status          String                 @default("queued") @db.VarChar(30)
  recipientsCount Int                    @default(0) @map("recipients_count")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  startedAt       DateTime?              @map("started_at") @db.Timestamp(6)
  completedAt     DateTime?              @map("completed_at") @db.Timestamp(6)
  messages        OutboundMessageQueue[]

  @@index([status, createdAt])
  @@map("broadcast_campaigns")
}

model OutboundMessageQueue {
  id            Int                @id @default(autoincrement())
  campaignId    Int?               @map("campaign_id")
  contactId     Int?               @map("contact_id")
  chatId        String             @map("chat_id") @db.VarChar(120)
  chatName      String?            @map("chat_name") @db.VarChar(255)
  recipientName String?            @map("recipient_name") @db.VarChar(255)
  type          String             @default("broadcast") @db.VarChar(50)
  priority      Int                @default(50)
  dedupeKey     String?            @unique @map("dedupe_key") @db.VarChar(180)
  prompt        String?
  messageText   String             @map("message_text")
  status        String             @default("queued") @db.VarChar(30)
  attempts      Int                @default(0)
  scheduledAt   DateTime           @default(now()) @map("scheduled_at") @db.Timestamp(6)
  lockedUntil   DateTime?          @map("locked_until") @db.Timestamp(6)
  sentAt        DateTime?          @map("sent_at") @db.Timestamp(6)
  lastError     String?            @map("last_error")
  rawPayload    Json?              @map("raw_payload")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime           @default(now()) @map("updated_at") @db.Timestamp(6)
  campaign      BroadcastCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  contact       Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([status, priority, scheduledAt])
  @@index([chatId, scheduledAt])
  @@index([contactId, type])
  @@map("outbound_message_queue")
}

model MaxChatState {
  id              Int       @id @default(autoincrement())
  chatId          String    @unique @map("chat_id") @db.VarChar(120)
  chatName        String?   @map("chat_name") @db.VarChar(255)
  lastPreviewText String?   @map("last_preview_text")
  lastPreviewTime String?   @map("last_preview_time") @db.VarChar(50)
  lastDirection   String?   @map("last_direction") @db.VarChar(20)
  lastInboundAt   DateTime? @map("last_inbound_at") @db.Timestamp(6)
  lastOutboundAt  DateTime? @map("last_outbound_at") @db.Timestamp(6)
  cooldownUntil   DateTime? @map("cooldown_until") @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([chatName])
  @@index([cooldownUntil])
  @@map("max_chat_state")
}
