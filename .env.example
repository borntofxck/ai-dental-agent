DATABASE_URL=postgresql://postgres:root@localhost:5432/ai_dental_agent

AGENT_API_PORT=3002
AGENT_API_URL=http://localhost:3002
N8N_WEBHOOK_URL=http://localhost:5678/webhook/incoming-message
MAX_ADAPTER_PORT=3001
MAX_WEB_URL=https://web.max.ru/
MAX_OPEN_BROWSER=true
MAX_HEADLESS=false
MAX_USER_DATA_DIR=./max-adapter/.auth/max-profile
MAX_ARTIFACTS_DIR=./max-adapter/artifacts
MAX_POLL_INTERVAL_MS=5000
REMINDER_POLL_INTERVAL_MS=60000
REMINDER_SEND_WINDOW_START=09:00
REMINDER_SEND_WINDOW_END=21:00
REMINDER_TIMEZONE=Europe/Moscow

MAX_SELECTOR_CHAT_LIST=
MAX_SELECTOR_CHAT_ITEM=
MAX_SELECTOR_MESSAGE_LIST=
MAX_SELECTOR_MESSAGE_ITEM=
MAX_SELECTOR_MESSAGE_INPUT=
MAX_SELECTOR_SEND_BUTTON=

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
CLASSIFIER_MODEL=llama-3.1-8b-instant
HUMANIZER_MODEL=llama-3.1-8b-instant
COMPLEX_MODEL=llama-3.3-70b-versatile
COMPLEX_MODEL_ENABLED=true
HUMANIZER_ENABLED=true
HUMANIZER_ONLY_FOR_COMPLEX=true
HUMANIZER_SKIP_SIMPLE=true
MAX_CLASSIFIER_INPUT_TOKENS=2000
MAX_HUMANIZER_INPUT_TOKENS=800
MAX_LAST_MESSAGES=6
MAX_MEMORY_CHARS=1000
MAX_CONTEXT_CHARS=4000

CLINIC_NAME=DentalCare
CLINIC_PHONE=+7XXXXXXXXXX
CLINIC_ADDRESS=Clinic address

# --- Аутентификация админки ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_please
# Секрет подписи сессии (если пусто — выводится из пароля). Задайте длинную случайную строку для прода.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12
# true только при работе по HTTPS (cookie с флагом Secure)
ADMIN_COOKIE_SECURE=false
# Опциональный ключ для служебных вебхуков (/incoming-message, /reminders/*).
# Если пусто — проверка выключена (n8n работает как раньше). Задайте, чтобы включить.
AGENT_API_KEY=
